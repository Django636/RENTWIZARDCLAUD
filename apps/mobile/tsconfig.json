{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src", "App.tsx", "src/global.d.ts"],
  "exclude": ["node_modules"]
}
