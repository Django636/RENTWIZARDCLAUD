{
  "name": "rentwizard",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "infra/prisma"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "postinstall": "cd infra/prisma && npx prisma generate",
    "db:validate": "cd infra/prisma && npx prisma validate",
    "db:migrate": "cd infra/prisma && npx prisma migrate dev",
    "db:migrate:deploy": "cd infra/prisma && npx prisma migrate deploy",
    "db:seed": "cd infra/prisma && npx prisma db seed",
    "db:generate": "cd infra/prisma && npx prisma generate",
    "db:studio": "cd infra/prisma && npx prisma studio",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.4.0",
    "eslint": "^9.15.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.0"
}
